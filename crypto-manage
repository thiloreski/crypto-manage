#!/bin/sh

DRY_RUN=1
OPEN="open"
CLOSE="close"
OP="nd"

if [ "$1" = "$OPEN" ]; then
    OP=$OPEN
elif [ "$1" = "$CLOSE" ]; then
    OP=$CLOSE
fi
shift

# Check for the "go" parameter to enable production/live run
for last_arg in "$@"; do :; done

if [ "$last_arg" = "go" ]; then
    DRY_RUN=0
    # Remove "go" from the argument list for further processing
    LIST=$(echo "$*" | sed 's/[[:space:]]*go$//')
else
    LIST="$*"
fi

# Display help if parameters are incorrect or missing
if [ "$OP" = "nd" ]; then
    echo "Usage: $0 [ open | close ] [luks_name]* [go]"
    echo "Example for dry-run:  $0 open backup_safe"
    echo "Example for live-run: $0 open backup_safe go"
    echo "crypto devices:"                             
    uci show cryptsetup                                
    exit 1
fi

# If no specific disk was passed, read all from OpenWrt configuration
if [ -z "$LIST" ]; then
    LIST=$(uci -q show cryptsetup | grep "=cryptsetup" | cut -d'.' -f2 | cut -d'=' -f1)
fi
# Still no device given?                                                               
if [ -z "$LIST" ]; then                                                                
   echo "No crypto device fould .. exiting"                                            
   exit                                                                                
fi                                                                                     

# --- OPEN MODE ---
if [ "$OP" = "$OPEN" ]; then
    echo "Decrypting: $LIST"
    for i in $LIST; do
        # Fetch values from OpenWrt UCI
        DEV=$(uci -q get cryptsetup.$i.device)
        MOUNT_POINT=$(uci -q show fstab | grep "device='/dev/mapper/$i'" | cut -d'.' -f2)
        TARGET=""
        [ -n "$MOUNT_POINT" ] && TARGET=$(uci -q get fstab.$MOUNT_POINT.target)

        if [ -z "$DEV" ]; then
            echo "✗ $i is not configured in /etc/config/cryptsetup!"
            continue
        fi

        if [ "$DRY_RUN" = "0" ]; then
            echo "-> Opening LUKS device $i ($DEV)..."
            cryptsetup open "$DEV" "$i"
            
            if [ -n "$TARGET" ]; then
                echo "-> Mounting to $TARGET..."
                mkdir -p "$TARGET"
                mount "/dev/mapper/$i" "$TARGET"
                echo "✓ Done."
            else
                echo "⚠ No automatic mount point found in /etc/config/fstab for /dev/mapper/$i."
            fi
        else
            echo "[Dry-Run] cryptsetup open $DEV $i"
            [ -n "$TARGET" ] && echo "[Dry-Run] mount /dev/mapper/$i $TARGET"
        fi
    done
fi

# --- CLOSE MODE ---
if [ "$OP" = "$CLOSE" ]; then
    echo "Locking: $LIST"
    for i in $LIST; do
        TARGET=$(mount | grep "/dev/mapper/$i" | awk '{print $3}')
        
        if [ -n "$TARGET" ]; then
            # Check if files are open/busy using standard BusyBox 'fuser'
            if fuser -s "$TARGET" 2>/dev/null; then
                echo "✗ Files on $TARGET are locked/busy! Unmount aborted."
                fuser -v "$TARGET"
                continue
            fi

            if [ "$DRY_RUN" = "0" ]; then
                echo "-> Unmounting $TARGET..."
                umount "$TARGET"
            else
                echo "[Dry-Run] umount $TARGET"
            fi
        fi

        if [ "$DRY_RUN" = "0" ]; then
            echo "-> Closing crypto container $i..."
            cryptsetup close "$i"
        else
            echo "[Dry-Run] cryptsetup close $i"
        fi
    done
fi
